<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gamevault.controller.MainController"
            styleClass="app-root"
            prefWidth="1280" prefHeight="800">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-bar">
            <padding><Insets top="10" right="24" bottom="10" left="24"/></padding>
            <ImageView fitWidth="220" fitHeight="70" preserveRatio="true">
                <image><Image url="@../images/logo.png"/></image>
            </ImageView>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Recherche..." prefWidth="260"
                       styleClass="search-field" onAction="#onSearch"/>
            <Button text="🔍" onAction="#onSearch" styleClass="small-button"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="8" prefWidth="220" styleClass="side-menu">
            <padding><Insets top="28" right="18" bottom="28" left="18"/></padding>
            <Label text="MENU" styleClass="menu-title"/>
            <Button text="📚  Collection"     maxWidth="Infinity" styleClass="menu-button-active" onAction="#onShowCollection"/>
            <Button text="➕  Ajouter un jeu" maxWidth="Infinity" styleClass="menu-button" onAction="#onAddGame"/>
            <Button text="⚙  Paramètres"     maxWidth="Infinity" styleClass="menu-button" onAction="#onSettings"/>
        </VBox>
    </left>

    <!-- CENTER -->
    <center>
        <VBox spacing="18" styleClass="content-area">
            <padding><Insets top="26" right="26" bottom="26" left="26"/></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Ma collection" styleClass="page-title"/>
                    <Label fx:id="subtitleLabel" text="" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Ajouter" styleClass="primary-button" onAction="#onAddGame"/>
            </HBox>

            <VBox spacing="10" styleClass="filter-card">
                <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Filtres :" styleClass="section-label"/>
                    <ComboBox fx:id="platformFilter" promptText="Toutes plateformes" prefWidth="180"/>
                    <ComboBox fx:id="statusFilter"   promptText="Tous statuts"       prefWidth="150"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Tri :" styleClass="section-label"/>
                    <Button text="Titre"      styleClass="small-button" onAction="#onSortTitle"/>
                    <Button text="Année"      styleClass="small-button" onAction="#onSortYear"/>
                    <Button text="Note"       styleClass="small-button" onAction="#onSortRating"/>
                    <Button text="Plateforme" styleClass="small-button" onAction="#onSortPlatform"/>
                </HBox>
            </VBox>

            <!-- Grille de jeux -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" styleClass="grid-scroll">
                <FlowPane fx:id="gameGrid" hgap="16" vgap="16" styleClass="game-grid">
                    <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                </FlowPane>
            </ScrollPane>

            <HBox alignment="CENTER_LEFT" styleClass="status-bar">
                <Label fx:id="statusBar" text="" styleClass="page-subtitle"/>
            </HBox>
        </VBox>
    </center>

    <!-- DETAIL PANEL -->
    <right>
        <ScrollPane fitToWidth="true" prefWidth="300" hbarPolicy="NEVER" styleClass="detail-scroll">
            <VBox spacing="14" styleClass="detail-panel">
                <padding><Insets top="28" right="20" bottom="28" left="20"/></padding>

                <Label fx:id="detailEmpty"
                       text="Sélectionnez un jeu&#10;pour voir ses détails"
                       styleClass="detail-empty" wrapText="true"
                       maxWidth="Infinity" textAlignment="CENTER"/>

                <VBox fx:id="detailContent" spacing="12" visible="false" managed="false">
                    <ImageView fx:id="detailCover" fitWidth="220" fitHeight="300"
                               preserveRatio="true"/>
                    <Label fx:id="detailTitle" styleClass="detail-title" wrapText="true"/>
                    <Separator/>
                    <GridPane hgap="10" vgap="8">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="85" minWidth="85"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="Plateforme"  styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="detailPlatform"  styleClass="detail-value" wrapText="true" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Année"        styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="detailYear"      styleClass="detail-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Développeur"  styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="detailDeveloper" styleClass="detail-value" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <Label text="Éditeur"      styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="detailPublisher" styleClass="detail-value" wrapText="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        <Label text="Note"         styleClass="detail-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="detailRating"    styleClass="detail-value" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        <Label text="Statut"       styleClass="detail-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="detailStatus"    styleClass="detail-value" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    </GridPane>
                    <Separator/>
                    <Label text="Description" styleClass="detail-label"/>
                    <Label fx:id="detailDescription" styleClass="description" wrapText="true"/>
                    <Separator/>
                    <HBox spacing="8">
                        <Button text="Modifier"  HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                styleClass="secondary-button" onAction="#onEditGame"/>
                        <Button text="Supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                styleClass="danger-button" onAction="#onDeleteGame"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </right>

</BorderPane>
